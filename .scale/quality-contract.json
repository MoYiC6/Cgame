{
  "version": "1.0",
  "project": {
    "name": "zuhao",
    "type": "monorepo",
    "stack": "polyglot",
    "techStack": [
      "Go",
      "Vue 3",
      "TypeScript",
      "Vite",
      "pnpm",
      "Gin",
      "PostgreSQL"
    ]
  },
  "agent": {
    "id": "claude-code",
    "scenarioMode": "standard"
  },
  "sourceOfTruth": {
    "agentEntry": "AGENTS.md / CLAUDE.md",
    "workflowState": ".scale/workflow.json",
    "runtimeCommands": ".agent/project.json",
    "qualityContract": ".scale/quality-contract.json",
    "skillRegistry": ".scale/skills-registry.json"
  },
  "taskLevels": [
    {
      "level": "S",
      "intent": "单点小改、文案、注释、低风险配置。",
      "requiredArtifacts": [
        "final response evidence"
      ],
      "requiredVerification": [
        "relevant command only"
      ]
    },
    {
      "level": "M",
      "intent": "普通功能、bugfix、2-5 个文件的行为变化。",
      "requiredArtifacts": [
        "explore.md",
        "plan.md",
        "verification.md",
        "summary.md"
      ],
      "requiredVerification": [
        "bash scripts/workflow/verify.sh default"
      ]
    },
    {
      "level": "L",
      "intent": "跨模块、接口契约、数据模型或高影响重构。",
      "requiredArtifacts": [
        "mini-prd.md when user-facing",
        "explore.md",
        "plan.md",
        "review.md",
        "verification.md",
        "summary.md"
      ],
      "requiredVerification": [
        "bash scripts/workflow/verify.sh fullstack"
      ]
    },
    {
      "level": "CRITICAL",
      "intent": "认证、权限、支付、生产配置、删除或迁移。",
      "requiredArtifacts": [
        "mini-prd.md",
        "rollback-plan",
        "security-review",
        "verification.md",
        "summary.md"
      ],
      "requiredVerification": [
        "bash scripts/workflow/verify.sh release --include-optional",
        "bash scripts/gates/G7-verify.sh"
      ]
    }
  ],
  "verificationProfiles": [
    {
      "id": "fast",
      "required": [
        "backend: go test ./..."
      ],
      "optional": [
        "backend: go vet ./..."
      ],
      "successRule": "只用于 S 级或局部验证，不能代表发布可用。"
    },
    {
      "id": "default",
      "required": [
        "backend: go vet ./...",
        "backend: go test ./...",
        "backend: go build ./..."
      ],
      "optional": [
        "backend: go test ./... -cover"
      ],
      "successRule": "M 级默认闭环，失败必须记录原因和修复循环。"
    },
    {
      "id": "frontend",
      "required": [
        "admin: pnpm lint",
        "admin: pnpm build",
        "admin: pnpm exec vue-tsc --noEmit"
      ],
      "optional": [
        "admin: automated test command when available"
      ],
      "successRule": "前端改动至少通过 lint/build/typecheck，直到真实测试脚本接入。"
    },
    {
      "id": "fullstack",
      "required": [
        "backend + admin: lint/build/typecheck"
      ],
      "optional": [
        "backend tests",
        "coverage",
        "security"
      ],
      "successRule": "跨前后端改动必须至少验证编译、静态检查和契约表面。"
    }
  ],
  "skillPolicy": {
    "mode": "progressive-disclosure",
    "maxAlwaysVisible": 24,
    "installSafety": [
      "只从可信仓库或已审查来源安装。",
      "安装前检查脚本、二进制、网络下载、postinstall、权限和 license。",
      "优先固定版本或 commit；禁止无审查执行 curl | bash。"
    ],
    "usageEvidence": [
      "说明为什么选这些 skills、MCP 或 CLI。",
      "记录实际调用的工具和输出证据。",
      "技能失败时记录失败原因和降级方案。"
    ]
  },
  "engineeringRedLines": [
    "不得声称未运行的验证通过。",
    "不得把临时日志、截图、视频和一次性脚本默认提交到 git。",
    "不得在日志、文档、测试报告中输出 token、密码、手机号、密钥和连接串。",
    "不得绕过后端错误处理、鉴权边界或前端请求封装约定。"
  ]
}
